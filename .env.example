# ---- 網站密碼保護 ----
# 設定後，開啟網站需要輸入此密碼才能使用
APP_PASSWORD=請替換成強密碼

# ---- Flask Session 金鑰（建議設定，避免 gunicorn 重啟後 session 失效）----
# 可用任意隨機字串，例如：python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ---- Gmail OAuth 2.0 ----
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
GMAIL_REFRESH_TOKEN=
GMAIL_USER=你的Gmail帳號@gmail.com

# ---- 可選：指定自訂 Excel 資料庫路徑（留空使用預設示範資料）----
# INVESTOR_WORKBOOK_PATH=./report_centric_investor_demo_dataset.xlsx

# ---- 伺服器埠（Railway 會自動設定，本機開發才需要手動設定）----
# PORT=3000
